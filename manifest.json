{
  "manifest_version": 3,
  "name": "JARVIS Mainframe AI",
  "version": "3.0",
  "description": "Cross-site voice-activated floating JARVIS HUD with a real (working) Gemini brain",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
